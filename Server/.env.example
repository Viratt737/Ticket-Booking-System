# ── MongoDB ─────────────────────────────────────────────────────────
MONGODB_URI=mongodb+srv://<user>:<password>@cluster.mongodb.net/ticket-booking

# ── Clerk (Backend) ──────────────────────────────────────────────────
CLERK_SECRET_KEY=sk_test_xxxxx
CLERK_PUBLISHABLE_KEY=pk_test_xxxxx

# ── TMDB ─────────────────────────────────────────────────────────────
TMDB_API_KEY=eyJhbGciOiJSUzI1NiJ9.xxxxx   # Bearer token (not v3 key)

# ── Stripe ───────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_xxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxx

# ── Email (Brevo SMTP) ───────────────────────────────────────────────
SMTP_USER=your_brevo_login@example.com
SMTP_PASS=your_brevo_smtp_key
SENDER_EMAIL=noreply@yourdomain.com

# ── App ──────────────────────────────────────────────────────────────
CLIENT_URL=http://localhost:5173
CURRENCY=$

# ── Inngest ──────────────────────────────────────────────────────────
# No additional env vars needed for local dev (Inngest Dev Server auto-discovers)
# For production, set INNGEST_SIGNING_KEY and INNGEST_EVENT_KEY in your host
